  "recordSets": [
    {
      "name": "aid1-aid2-coexistence-prefers-aid2",
      "records": [
        "v=aid1;u=https://v1.example.com/mcp;p=mcp",
        "v=aid2;u=https://v2.example.com/mcp;p=mcp"
      ],
      "expectedSelected": {
        "v": "aid2",
        "uri": "https://v2.example.com/mcp",
        "proto": "mcp"
      },
      "metadata": {
        "selectionRule": "When exactly one valid aid2 record coexists with aid1 records at the same owner name, version-aware clients prefer aid2."
      }
    },
    {
      "name": "unknown-future-version-ignored-when-aid2-present",
      "records": [
        "v=aid3;u=https://future.example.com/mcp;p=mcp",
        "v=aid2;u=https://v2.example.com/mcp;p=mcp"
      ],
      "expectedSelected": {
        "v": "aid2",
        "uri": "https://v2.example.com/mcp",
        "proto": "mcp"
      },
      "metadata": {
        "selectionRule": "Unknown future versions are not selected over a supported aid2 record."
      }
    },
    {
      "name": "unknown-future-version-only",
      "records": ["v=aid3;u=https://future.example.com/mcp;p=mcp"],
      "expectedErrorCode": "ERR_INVALID_TXT",
      "metadata": {
        "selectionRule": "Unknown future versions must not be treated as aid2-compatible records."
      }
    },
    {
      "name": "valid-aid2-with-malformed-aid2-selects-valid-aid2",
      "records": [
        "v=aid2;u=http://bad.example.com/mcp;p=mcp",
        "v=aid2;u=https://v2.example.com/mcp;p=mcp"
      ],
      "expectedSelected": {
        "v": "aid2",
        "uri": "https://v2.example.com/mcp",
        "proto": "mcp"
      },
      "metadata": {
        "selectionRule": "When exactly one valid aid2 record exists, malformed aid2 records at the same owner name do not block selection."
      }
    },
    {
      "name": "malformed-aid2-with-valid-aid1-selects-aid1",
      "records": [
        "v=aid2;u=http://bad.example.com/mcp;p=mcp",
        "v=aid1;u=https://v1.example.com/mcp;p=mcp"
      ],
      "expectedSelected": {
        "v": "aid1",
        "uri": "https://v1.example.com/mcp",
        "proto": "mcp"
      },
      "metadata": {
        "selectionRule": "Malformed aid2 records do not block fallback to a single valid aid1 record."
      }
    },
    {
      "name": "only-malformed-aid-like-txt-no-well-known-fallback",
      "records": ["v=aid3;u=https://future.example.com/mcp;p=mcp"],
      "expectedErrorCode": "ERR_INVALID_TXT",
      "metadata": {
        "selectionRule": "When DNS contains only malformed AID-like TXT, clients return ERR_INVALID_TXT and do not use well-known fallback."
      }
    }
  ]
}
